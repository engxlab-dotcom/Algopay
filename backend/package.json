{
  "name": "@algostack/backend",
  "version": "0.1.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/server.ts",
    "build": "rimraf dist && tsc",
    "start": "node dist/server.js",
    "compile:contracts": "ALGOD_SERVER=https://testnet-api.algonode.cloud ALGOD_PORT=443 ALGOD_TOKEN=a tealscript contracts/MerchantRegistry.ts contracts/artifacts && ALGOD_SERVER=https://testnet-api.algonode.cloud ALGOD_PORT=443 ALGOD_TOKEN=a tealscript contracts/PaymentProcessor.ts contracts/artifacts",
    "deploy:contracts": "ts-node contracts/deploy.ts",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset"
  },
  "dependencies": {
    "@algorandfoundation/algokit-utils": "^9.0.0",
    "@allbridge/bridge-core-sdk": "^2.0.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "algosdk": "^3.0.0",
    "axios": "^1.7.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "ethers": "^6.13.0",
    "express": "^4.19.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.0.0",
    "isomorphic-dompurify": "^3.7.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "p-retry": "^6.2.0",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@algorandfoundation/tealscript": "^0.107.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.1.0",
    "rimraf": "^6.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
}
